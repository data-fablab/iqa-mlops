{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["iqa", "mvp"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "IQA - Vue d'ensemble",
  "uid": "iqa-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Modele actif",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 10, "x": 0, "y": 0 },
      "options": { "showHeader": true },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true },
            "renameByName": {
              "feature_ae_version": "Feature-AE",
              "roi_model_version": "ROI segmenter"
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "iqa_active_model_info",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 10, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_api_up", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Inference up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 13, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_inference_up", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GPU lock (demo)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "libre", "color": "green" }, "1": { "text": "tenu (inference)", "color": "blue" } } }
          ]
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_inference_gpu_lock_held", "instant": true }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Latence predict (moy, 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 4 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iqa_predict_latency_seconds_sum[5m]) / clamp_min(rate(iqa_predict_latency_seconds_count[5m]), 1)",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Distribution V/O/R",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 4 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value"] }, "pieType": "donut" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "iqa_prediction_total",
          "legendFormat": "{{decision}}",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Decisions dans le temps (taux 5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(iqa_prediction_total[5m])",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "ROI fail (cumul)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "iqa_roi_fail_total",
          "legendFormat": "roi_fail"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Incidents IA",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_ai_security_incident_total", "legendFormat": "incidents IA" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_feedback_conflict_total", "legendFormat": "conflits feedback" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_unsafe_train_blocked_total", "legendFormat": "train bloque" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Erreurs (feedback / reload)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_invalid_feedback_total", "legendFormat": "feedback invalide" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "iqa_reload_refused_total", "legendFormat": "reload refuse" }
      ]
    }
  ]
}
