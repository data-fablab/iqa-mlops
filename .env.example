IQA_ENV=local
IQA_API_HOST=0.0.0.0
IQA_API_PORT=8000
IQA_INFERENCE_URL=http://localhost:8100

IQA_POSTGRES_USER=iqa
IQA_POSTGRES_PASSWORD=change-me-postgres-password
IQA_METADATA_DB_URL=postgresql://iqa:change-me-postgres-password@localhost:5432/iqa_metadata
IQA_MLFLOW_DB_URL=postgresql://iqa:change-me-postgres-password@localhost:5432/mlflow
IQA_AIRFLOW_DB_URL=postgresql://iqa:change-me-postgres-password@localhost:5432/airflow
IQA_MLFLOW_TRACKING_URI=http://localhost:5000
# Standard MLflow/boto3 env var the iqa runtime actually reads (set alongside the
# IQA_ prefixed one above). Forwarded to Airflow task containers (ADR 0008).
MLFLOW_TRACKING_URI=http://mlflow:5000
IQA_MLFLOW_ALLOWED_HOSTS=localhost,localhost:5000,127.0.0.1,127.0.0.1:5000,10.0.0.27,10.0.0.27:5000,100.64.19.73,100.64.19.73:5000,mlflow,mlflow:5000

IQA_S3_ENDPOINT_URL=http://localhost:9000
IQA_S3_ACCESS_KEY_ID=change-me
IQA_S3_SECRET_ACCESS_KEY=change-me
IQA_S3_REGION=us-east-1
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=change-me-minio-user
AWS_SECRET_ACCESS_KEY=change-me-minio-password

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password

IQA_ACTIVE_MODEL_ALIAS=prod
IQA_MLFLOW_REGISTRY_SOURCE_OF_TRUTH=true
IQA_ADMIN_TOKEN=change-me-admin-token
IQA_SERVICE_TOKEN=change-me-service-token
IQA_ROI_MODEL_VERSION=roi_segmenter_v001_fixed
IQA_FEATURE_AE_MODEL_VERSION=rd_feature_ae_gated_v001_bootstrap
IQA_TEACHER_VERSION=teacher_resnet18_imagenet_fixed

# Single-GPU lock (RTX 3060): shared lock file between inference and trainer.
# Set IQA_GPU_DEMO_HOLD=1 so the live inference demo holds the GPU and any
# concurrent iqa-trainer run is refused (exit 75). Leave 0 outside the demo.
IQA_GPU_LOCK_PATH=/var/run/iqa-gpu/gpu.lock
IQA_GPU_DEMO_HOLD=0

# Airflow containerised tasks (ADR 0008): the scheduler launches task containers
# via the host Docker socket. IQA_DOCKER_GID must match `getent group docker` on
# the host so the airflow user can talk to the socket.
IQA_DOCKER_GID=984
# Override the per-role images the task containers run (defaults match local builds).
IQA_IMAGE_DATA=iqa-data:local
IQA_IMAGE_ML=iqa-ml:local

# Extra env var names to forward from the scheduler into Airflow task containers,
# on top of the built-in allowlist (data plane / MLflow / tokens). Comma-separated.
# The scheduler env is never bulk-forwarded; only allowlisted names cross (ADR 0008).
# IQA_TASK_ENV_PASSTHROUGH=

# Prod registry + pinned tag for the per-role IQA images (overlay docker-compose.prod.yml).
# Always a fixed version, never `latest`, for reproducible deploys; bump on each release.
IQA_IMAGE_REGISTRY=data-fablab
IQA_IMAGE_TAG=v0.1.0
